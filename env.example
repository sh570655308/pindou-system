# 服务器端口
PORT=5000

# JWT 密钥（用于加密用户登录凭证，请修改为任意随机字符串）
JWT_SECRET=your-secret-key-change-in-production

# API 地址（前端使用，单容器部署时无需修改）
REACT_APP_API_URL=/api

# Node 环境
NODE_ENV=production

# ========== OCR API 配置（可选） ==========
# 用于图纸物料识别功能，不配置不影响其他功能

# 推荐使用硅基流动 DeepSeek-OCR（目前免费）
# 注册地址：https://cloud.siliconflow.cn/i/QIYTYm6u
OCR_API_KEY=

# API 地址（无需修改）
OCR_API_URL=https://api.siliconflow.cn/v1
