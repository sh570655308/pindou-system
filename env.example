# 服务器端口（映射到主机的端口）
PORT=5000

# JWT 密钥（生产环境请修改为强密码）
JWT_SECRET=your-secret-key-change-in-production

# API 地址（前端使用，单容器部署时使用相对路径，无需修改）
# 开发环境可以设置为：http://localhost:5000/api
# 生产环境使用反向代理时，前端会自动使用相对路径 /api
REACT_APP_API_URL=/api

# Node 环境
NODE_ENV=production

# ========== OCR API 配置 ==========
# 图纸物料识别功能需要配置 OCR API
# 如不配置，OCR 识别功能将不可用，但其他功能正常

# DeepSeek-OCR API Key（主要使用，推荐）
# 获取地址：https://cloud.siliconflow.cn/
OCR_API_KEY=

# DeepSeek-OCR API URL（通常无需修改）
OCR_API_URL=https://api.siliconflow.cn/v1

# OCR.space API Key（备用，可选）
# 获取地址：https://ocr.space/
OCR_SPACE_API_KEY=

